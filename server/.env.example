# Django
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=*

# PostgreSQL (docker-compose подставляет POSTGRES_HOST=db в сервисах)
POSTGRES_DB=smartinv
POSTGRES_USER=smartinv
POSTGRES_PASSWORD=smartinv

# Локальный manage.py без Docker — хост БД:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Celery / Redis (в Docker по умолчанию redis://redis:6379/0 в compose)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=900

# GigaChat (OAuth: заголовок Authorization = значение GIGACHAT_AUTH_KEY, обычно уже с префиксом Basic …)
GIGACHAT_AUTH_KEY=Basic YOUR_BASE64_CLIENT_ID_COLON_CLIENT_SECRET
# Опционально, для справки / логов (в OAuth может хватать только Basic-ключа):
GIGACHAT_CLIENT_ID=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=false
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_MODEL=GigaChat

# Совместимость: если в .env остались старые имена от кабинета SberDevices
# CLIENT_ID=
# SCOPE=GIGACHAT_API_PERS

PGADMIN_DEFAULT_EMAIL=admin@smartinv.local
PGADMIN_DEFAULT_PASSWORD=admin
