# Пример файла docker-compose.override.yml
# Скопируйте этот файл в docker-compose.override.yml для локальных настроек
# Этот файл автоматически подхватывается docker-compose

version: '3.8'

services:
  db:
    # Для разработки можно изменить порт
    ports:
      - "3307:3306"
    
    # Или добавить дополнительные переменные окружения
    # environment:
    #   MYSQL_ROOT_PASSWORD: your_custom_root_password
