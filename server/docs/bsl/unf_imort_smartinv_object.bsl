////////////////////////////////////////////////////////////////////////////////
// Внешняя обработка "Импорт XML в УНФ"
// Функционал:
// - Потоковое чтение XML (ЧтениеXML)
// - Импорт документов инвентаризации
// - Дедупликация по XML_SESSION_ID в комментарии документа
// - Транзакция
// - Логирование (Сообщить)
// - Обработка ошибок
////////////////////////////////////////////////////////////////////////////////

////////////////////////////////////////////////////////////////////////////////
// ОСНОВНАЯ ПРОЦЕДУРА ИМПОРТА
////////////////////////////////////////////////////////////////////////////////

&НаСервере
Процедура ИмпортXML(ПутьФайла) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ПутьФайла) Тогда
		ВызватьИсключение "Не указан путь к XML файлу.";
	КонецЕсли;
	
	ФайлXML = Новый Файл(ПутьФайла);
	Если НЕ (ФайлXML.Существует()) Тогда
		ВызватьИсключение "Файл не найден: " + ПутьФайла;
	КонецЕсли;
	
	Сообщить("====================================");
	Сообщить("Старт импорта XML");
	Сообщить("Файл: " + ПутьФайла);
	Сообщить("====================================");
	
	МассивИнвентаризаций = Новый Массив;
	ЧтXML = Новый ЧтениеXML;
	
	Попытка
		
		ЧтXML.ОткрытьФайл(ПутьФайла);
		
		ТекущаяСессия = Неопределено;
		
		Пока ЧтXML.Прочитать() Цикл
			
			// Закрытие inventory_session
			Если ЧтXML.ТипУзла = ТипУзлаXML.КонецЭлемента Тогда
				Если НРег(ЧтXML.Имя) = "inventory_session" Тогда
					ТекущаяСессия = Неопределено;
				КонецЕсли;
				Продолжить;
			КонецЕсли;
			
			Если ЧтXML.ТипУзла <> ТипУзлаXML.НачалоЭлемента Тогда
				Продолжить;
			КонецЕсли;
			
			Имя = НРег(ЧтXML.Имя);
			
			// =========================
			// СЕССИЯ ИНВЕНТАРИЗАЦИИ
			// =========================
			Если Имя = "inventory_session" Тогда
				
				ТекущаяСессия = Новый Структура;
				ТекущаяСессия.Вставить("id", ЧтXML.ПолучитьАтрибут("id"));
				ТекущаяСессия.Вставить("status", ЧтXML.ПолучитьАтрибут("status"));
				ТекущаяСессия.Вставить("started_at", ЧтXML.ПолучитьАтрибут("started_at"));
				
				// Юрлицо (для установки организации документа)
				ТекущаяСессия.Вставить("legal_entity_id", ЧтXML.ПолучитьАтрибут("legal_entity_id"));
				ТекущаяСессия.Вставить("legal_entity_name", ЧтXML.ПолучитьАтрибут("legal_entity_name"));
				ТекущаяСессия.Вставить("legal_entity_tax_id", ЧтXML.ПолучитьАтрибут("legal_entity_tax_id"));
				
				ТекущаяСессия.Вставить("items", Новый Массив);
				МассивИнвентаризаций.Добавить(ТекущаяСессия);
			
			// =========================
			// ITEM ВНУТРИ СЕССИИ
			// =========================
			ИначеЕсли Имя = "item" Тогда
				
				Если ТекущаяСессия <> Неопределено Тогда
					
					Стр = Новый Структура;
					Стр.Вставить("inventory_number", ЧтXML.ПолучитьАтрибут("inventory_number"));
					Стр.Вставить("asset_name", ЧтXML.ПолучитьАтрибут("asset_name"));
					Стр.Вставить("quantity", ЧтXML.ПолучитьАтрибут("quantity"));
					Стр.Вставить("price", ЧтXML.ПолучитьАтрибут("price"));
					Стр.Вставить("condition", ЧтXML.ПолучитьАтрибут("condition"));
					Стр.Вставить("comment", ЧтXML.ПолучитьАтрибут("comment"));
					
					ТекущаяСессия.items.Добавить(Стр);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ЧтXML.Закрыть();
		
	Исключение
		Попытка
			ЧтXML.Закрыть();
		Исключение
		КонецПопытки;
		ВызватьИсключение "Ошибка чтения XML: " + ОписаниеОшибки();
	КонецПопытки;
	
	Сообщить("Найдено сессий: " + МассивИнвентаризаций.Количество());
	
	НачатьТранзакцию();
	
	Попытка
		
		Для Каждого Сессия Из МассивИнвентаризаций Цикл
			ИмпортИнвентаризации(Сессия);
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		Сообщить("Импорт завершен успешно.");
		
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение "Ошибка импорта: " + ОписаниеОшибки();
	КонецПопытки;
	
КонецПроцедуры


////////////////////////////////////////////////////////////////////////////////
// ИМПОРТ ДОКУМЕНТА ИНВЕНТАРИЗАЦИИ
////////////////////////////////////////////////////////////////////////////////

&НаСервере
Процедура ИмпортИнвентаризации(Сессия)
	
	XML_ID = СокрЛП("" + Сессия.id);
	Если НЕ ЗначениеЗаполнено(XML_ID) Тогда
		Сообщить("Сессия пропущена: пустой id.");
		Возврат;
	КонецЕсли;
	
	Маркер = "XML_SESSION_ID=" + XML_ID;
	
	Ссылка = НайтиДокИнвентаризацииПоМаркеру(Маркер);
	Если Ссылка = Неопределено Тогда
		Док = Документы.ИнвентаризацияЗапасов.СоздатьДокумент();
		Сообщить("Создание документа: " + XML_ID);
	Иначе
		Док = Ссылка.ПолучитьОбъект();
		Сообщить("Обновление документа: " + XML_ID);
	КонецЕсли;
	
	ДатаДок = ДатаИзISO8601(СокрЛП("" + Сессия.started_at));
	Если ДатаДок = Неопределено Тогда
		ДатаДок = ТекущаяДата();
	КонецЕсли;
	
	Док.Дата = ДатаДок;
	Док.Комментарий = Маркер + "; STATUS=" + СокрЛП("" + Сессия.status);
	
	// Организация документа
	Орг = Неопределено;
	
	ИННОрг = СокрЛП("" + Сессия.legal_entity_tax_id);
	Если ЗначениеЗаполнено(ИННОрг) Тогда
		Орг = НайтиОрганизациюПоИНН(ИННОрг);
	КонецЕсли;
	
	Если Орг = Неопределено Тогда
		Орг = НайтиОрганизациюПоXMLИлиИНН(СокрЛП("" + Сессия.legal_entity_id));
	КонецЕсли;
	
	Если Орг = Неопределено Тогда
		Орг = НайтиОрганизациюПоНаименованию(СокрЛП("" + Сессия.legal_entity_name));
	КонецЕсли;
	
	Если Орг <> Неопределено Тогда
		Попытка
			Док.Организация = Орг;
		Исключение
			Сообщить("Не удалось установить реквизит Док.Организация.");
		КонецПопытки;
	Иначе
		Сообщить("Организация не найдена. legal_entity_id=" 
			+ СокрЛП("" + Сессия.legal_entity_id) 
			+ ", tax_id=" + СокрЛП("" + Сессия.legal_entity_tax_id) 
			+ ", name=" + СокрЛП("" + Сессия.legal_entity_name));
	КонецЕсли;
	
	ИмяТЧ = ИмяТабличнойЧастиИнвентаризации(Док);
	Если НЕ ЗначениеЗаполнено(ИмяТЧ) Тогда
		ВызватьИсключение "У документа ИнвентаризацияЗапасов не найдена табличная часть.";
	КонецЕсли;
	
	ТЧ = Док[ИмяТЧ];
	ТЧ.Очистить();
	
	Для Каждого Item Из Сессия.items Цикл
		
		ИнвНомер = СокрЛП("" + Item.inventory_number);
		НаименованиеИзXML = СокрЛП("" + Item.asset_name);
		
		Если НЕ ЗначениеЗаполнено(ИнвНомер) И НЕ ЗначениеЗаполнено(НаименованиеИзXML) Тогда
			Сообщить("Строка item пропущена: пустые inventory_number и asset_name.");
			Продолжить;
		КонецЕсли;
		
		Номенклатура = НайтиИлиСоздатьНоменклатуру(ИнвНомер, НаименованиеИзXML);
		Если Номенклатура = Неопределено Тогда
			Сообщить("Номенклатура не создана/не найдена. Строка пропущена.");
			Продолжить;
		КонецЕсли;
		
		Кол = БезопасноВЧисло(Item.quantity, 1);
		Цена = БезопасноВЧисло(Item.price, 0);
		
		СтрТЧ = ТЧ.Добавить();
		
		// Без обращения к Метаданные() у строки ТЧ
		Попытка СтрТЧ.Номенклатура = Номенклатура; Исключение КонецПопытки;
		Попытка СтрТЧ.Количество = Кол; Исключение КонецПопытки;
		Попытка СтрТЧ.Цена = Цена; Исключение КонецПопытки;
		Попытка СтрТЧ.Сумма = Кол * Цена; Исключение КонецПопытки;
		Попытка СтрТЧ.Комментарий = "COND=" + СокрЛП("" + Item.condition) + "; " + СокрЛП("" + Item.comment); Исключение КонецПопытки;
		
	КонецЦикла;
	
	Док.Записать();
	
КонецПроцедуры


////////////////////////////////////////////////////////////////////////////////
// НОМЕНКЛАТУРА: ПОИСК/СОЗДАНИЕ
////////////////////////////////////////////////////////////////////////////////

&НаСервере
Функция НайтиИлиСоздатьНоменклатуру(Артикул, Наименование) Экспорт
	
	Артикул = СокрЛП("" + Артикул);
	Наименование = СокрЛП("" + Наименование);
	
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда
		Наименование = ?(ЗначениеЗаполнено(Артикул), Артикул, "Импорт из SmartInv");
	КонецЕсли;
	
	// 1) Поиск по артикулу
	Если ЗначениеЗаполнено(Артикул) Тогда
		Ном = НайтиНоменклатуруПоАртикулу(Артикул);
		Если Ном <> Неопределено Тогда
			Возврат Ном;
		КонецЕсли;
	КонецЕсли;
	
	// 2) Поиск по наименованию
	Ном = НайтиНоменклатуруПоНаименованию(Наименование);
	Если Ном <> Неопределено Тогда
		Попытка
			ОбъектНом = Ном.ПолучитьОбъект();
			Если ЗначениеЗаполнено(Артикул) И НЕ ЗначениеЗаполнено(ОбъектНом.Артикул) Тогда
				ОбъектНом.Артикул = Артикул;
				ОбъектНом.Записать();
			КонецЕсли;
		Исключение
		КонецПопытки;
		Возврат Ном;
	КонецЕсли;
	
	// 3) Создание
	Попытка
		ОбъектНовый = Справочники.Номенклатура.СоздатьЭлемент();
		ОбъектНовый.Наименование = Наименование;
		
		Если ЗначениеЗаполнено(Артикул) Тогда
			Попытка ОбъектНовый.Артикул = Артикул; Исключение КонецПопытки;
		КонецЕсли;
		
		// Маркер источника
		Попытка ОбъектНовый.Комментарий = "Создано импортом SmartInv"; Исключение КонецПопытки;
		
		ОбъектНовый.Записать();
		Сообщить("Создана номенклатура: " + Наименование + " (Артикул=" + Артикул + ")");
		Возврат ОбъектНовый.Ссылка;
		
	Исключение
		Сообщить("Не удалось создать номенклатуру: " + Наименование + ". Ошибка: " + ОписаниеОшибки());
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция НайтиНоменклатуруПоНаименованию(Наименование)
	
	Наименование = СокрЛП("" + Наименование);
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Ном.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Ном
	|ГДЕ
	|	Ном.Наименование = &Наименование";
	Запрос.УстановитьПараметр("Наименование", Наименование);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// ОРГАНИЗАЦИЯ
////////////////////////////////////////////////////////////////////////////////

&НаСервере
Функция НайтиОрганизациюПоИНН(ИНН)
	
	ИНН = СокрЛП("" + ИНН);
	Если НЕ ЗначениеЗаполнено(ИНН) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Орг.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Организации КАК Орг
	|ГДЕ
	|	Орг.ИНН = &ИНН";
	Запрос.УстановитьПараметр("ИНН", ИНН);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция НайтиОрганизациюПоНаименованию(Наименование)
	
	Наименование = СокрЛП("" + Наименование);
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Орг.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Организации КАК Орг
	|ГДЕ
	|	Орг.Наименование = &Наименование";
	Запрос.УстановитьПараметр("Наименование", Наименование);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция НайтиОрганизациюПоXMLИлиИНН(Ключ) Экспорт
	
	Ключ = СокрЛП("" + Ключ);
	Если НЕ ЗначениеЗаполнено(Ключ) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Попробуем как ИНН
	Орг = НайтиОрганизациюПоИНН(Ключ);
	Если Орг <> Неопределено Тогда
		Возврат Орг;
	КонецЕсли;
	
	// fallback по комментарию XML_ID=
	Запрос2 = Новый Запрос;
	Запрос2.Текст =
	"ВЫБРАТЬ
	|	Орг.Ссылка КАК Ссылка,
	|	Орг.Комментарий КАК Комментарий
	|ИЗ
	|	Справочник.Организации КАК Орг";
	
	Выборка2 = Запрос2.Выполнить().Выбрать();
	Пока Выборка2.Следующий() Цикл
		Если СтрНайти("" + Выборка2.Комментарий, Ключ) > 0 Тогда
			Возврат Выборка2.Ссылка;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// ТАБЛИЧНАЯ ЧАСТЬ ДОКУМЕНТА
////////////////////////////////////////////////////////////////////////////////

&НаСервере
Функция ИмяТабличнойЧастиИнвентаризации(ДокОбъект) Экспорт
	
	Кандидаты = Новый Массив;
	Кандидаты.Добавить("Товары");
	Кандидаты.Добавить("Запасы");
	Кандидаты.Добавить("Таблица");
	Кандидаты.Добавить("ТоварыНаСкладе");
	Кандидаты.Добавить("ТоварыПоУчету");
	
	Для Каждого ИмяТЧ Из Кандидаты Цикл
		Попытка
			ТЧ = ДокОбъект[ИмяТЧ];
			Если ТЧ <> Неопределено Тогда
				Возврат ИмяТЧ;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЦикла;
	
	Попытка
		Для Каждого МетаТЧ Из ДокОбъект.Метаданные().ТабличныеЧасти Цикл
			Возврат МетаТЧ.Имя;
		КонецЦикла;
	Исключение
	КонецПопытки;
	
	Возврат "";
	
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// ПОИСК ДУБЛЕЙ ДОКУМЕНТОВ
////////////////////////////////////////////////////////////////////////////////

&НаСервере
Функция НайтиДокИнвентаризацииПоМаркеру(Маркер)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Док.Ссылка КАК Ссылка,
	|	Док.Комментарий КАК Комментарий
	|ИЗ
	|	Документ.ИнвентаризацияЗапасов КАК Док";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ТекстКомментария = "";
		Если ЗначениеЗаполнено(Выборка.Комментарий) Тогда
			ТекстКомментария = "" + Выборка.Комментарий;
		КонецЕсли;
		
		Если СтрНайти(ТекстКомментария, Маркер) > 0 Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// НОМЕНКЛАТУРА ПО АРТИКУЛУ
////////////////////////////////////////////////////////////////////////////////

&НаСервере
Функция НайтиНоменклатуруПоАртикулу(Артикул)
	
	Артикул = СокрЛП("" + Артикул);
	Если НЕ ЗначениеЗаполнено(Артикул) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Ном.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Ном
	|ГДЕ
	|	Ном.Артикул = &Артикул";
	
	Запрос.УстановитьПараметр("Артикул", Артикул);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции


////////////////////////////////////////////////////////////////////////////////
// УТИЛИТЫ
////////////////////////////////////////////////////////////////////////////////

&НаСервере
Функция БезопасноВЧисло(Значение, ЗначениеПоУмолчанию)
	
	С = СокрЛП("" + Значение);
	Если НЕ ЗначениеЗаполнено(С) Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Попытка
		С = СтрЗаменить(С, ",", ".");
		Возврат Число(С);
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция ДатаИзISO8601(СтрокаДаты)
	
	СтрокаДаты = СокрЛП("" + СтрокаДаты);
	Если НЕ ЗначениеЗаполнено(СтрокаДаты) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		
		С = СтрЗаменить(СтрокаДаты, "T", " ");
		С = СтрЗаменить(С, "-", "");
		С = СтрЗаменить(С, ":", "");
		С = СтрЗаменить(С, " ", "");
		
		Если СтрДлина(С) < 14 Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Возврат Дата(
			Число(Лев(С, 4)),
			Число(Сред(С, 5, 2)),
			Число(Сред(С, 7, 2)),
			Число(Сред(С, 9, 2)),
			Число(Сред(С, 11, 2)),
			Число(Сред(С, 13, 2))
		);
		
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции