// Модуль объекта внешней обработки «Выгрузка инвентаризаций УНФ → XML SmartInv».
// Формат совместим с импортом Django (см. inventory/services.py): exchange, legal_entities,
// locations, employees, assets, inventory_sessions, write_off_acts.
//
// ВАЖНО:
// 1) В запросе ниже используется документ ИнвентаризацияЗапасов. Если в вашей базе имя другое,
//    замените фрагмент «Документ.ИнвентаризацияЗапасов» на актуальное имя из конфигуратора.
// 2) Реквизиты шапки (Организация, склад, дата) читаются через Попытка — подстройте имена
//    под вашу версию УНФ при необходимости.
// 3) Блок write_off_acts выгружается пустым; при необходимости расширьте запросом по документам списания.

#Область ПрограммныйИнтерфейс

Процедура ВыгрузитьИнвентаризацииВXML(ПолноеИмяФайла) Экспорт

	Если ПустаяСтрока(ПолноеИмяФайла) Тогда
		ВызватьИсключение "Не указан путь к файлу XML.";
	КонецЕсли;

	Запись = Новый ЗаписьXML;
	Запись.ОткрытьФайл(ПолноеИмяФайла, КодировкаТекста.UTF8);
	Запись.ЗаписатьОбъявлениеXML();

	Запись.ЗаписатьНачалоЭлемента("exchange");
	ЗаписатьАтрибутыКорня(Запись);

	КэшОрг = Новый Соответствие;
	КэшСкладов = Новый Соответствие;
	КэшНом = Новый Соответствие;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Инв.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ИнвентаризацияЗапасов КАК Инв";

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьКэшПоДокументу(Выборка.Ссылка, КэшОрг, КэшСкладов, КэшНом);
	КонецЦикла;

	Запись.ЗаписатьНачалоЭлемента("legal_entities");
	Для Каждого КЗ Из КэшОрг Цикл
		ЗаписатьЮрЛицо(Запись, КЗ.Значение);
	КонецЦикла;
	Запись.ЗаписатьКонецЭлемента(); // legal_entities

	Запись.ЗаписатьНачалоЭлемента("locations");
	Для Каждого КЗ Из КэшСкладов Цикл
		ЗаписатьЛокацию(Запись, КЗ.Значение);
	КонецЦикла;
	Запись.ЗаписатьКонецЭлемента(); // locations

	Запись.ЗаписатьНачалоЭлемента("employees");
	Запись.ЗаписатьКонецЭлемента(); // employees — при необходимости дополните выборкой из УНФ

	Запись.ЗаписатьНачалоЭлемента("assets");
	Для Каждого КЗ Из КэшНом Цикл
		ЗаписатьАктив(Запись, КЗ.Значение);
	КонецЦикла;
	Запись.ЗаписатьКонецЭлемента(); // assets

	Запись.ЗаписатьНачалоЭлемента("inventory_sessions");
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаписатьСессиюИнвентаризации(Запись, Выборка.Ссылка, КэшНом);
	КонецЦикла;
	Запись.ЗаписатьКонецЭлемента(); // inventory_sessions

	Запись.ЗаписатьНачалоЭлемента("write_off_acts");
	Запись.ЗаписатьКонецЭлемента(); // write_off_acts

	Запись.ЗаписатьКонецЭлемента(); // exchange
	Запись.Закрыть();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаписатьАтрибутыКорня(Запись)

	Запись.ЗаписатьАтрибут("format_version", "2.0");
	Запись.ЗаписатьАтрибут("generated_at", XMLСтрока(ТекущаяДатаСеанса()));

КонецПроцедуры

Функция ИдентификаторСсылки(Ссылка)

	Если Ссылка = Неопределено Или Ссылка.Пустая() Тогда
		Возврат "";
	КонецЕсли;
	Возврат Строка(Ссылка.УникальныйИдентификатор());

КонецФункции

Функция ИменаРеквизитовОрганизация()

	М = Новый Массив;
	М.Добавить("Организация");
	М.Добавить("ОрганизацияДокумента");
	Возврат М;

КонецФункции

Функция ИменаРеквизитовСклад()

	М = Новый Массив;
	М.Добавить("СтруктурнаяЕдиница");
	М.Добавить("Склад");
	М.Добавить("СкладКомпании");
	Возврат М;

КонецФункции

Функция ТекстРеквизитаШапки(ДокОбъект, ИменаРеквизитов)

	Для Каждого Имя Из ИменаРеквизитов Цикл
		Попытка
			Зн = ДокОбъект[Имя];
			Если Зн <> Неопределено И Не Зн.Пустая() Тогда
				Возврат Имя;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЦикла;
	Возврат "";

КонецФункции

Функция ПолучитьКоллекциюСтрокТоваров(ДокОбъект)

	Кандидаты = Новый Массив;
	Кандидаты.Добавить("Товары");
	Кандидаты.Добавить("Запасы");
	Кандидаты.Добавить("ЗапасыНаСкладах");
	Кандидаты.Добавить("ИнвентаризационнаяОпись");

	Для Каждого ИмяТЧ Из Кандидаты Цикл
		Попытка
			Возврат ДокОбъект[ИмяТЧ];
		Исключение
		КонецПопытки;
	КонецЦикла;

	Возврат Неопределено;

КонецФункции

Процедура ЗаполнитьКэшПоДокументу(СсылкаДок, КэшОрг, КэшСкладов, КэшНом)

	ДокОб = СсылкаДок.ПолучитьОбъект();

	ИмяОрг = ТекстРеквизитаШапки(ДокОб, ИменаРеквизитовОрганизация());
	Если Не ПустаяСтрока(ИмяОрг) Тогда
		Орг = ДокОб[ИмяОрг];
		ИдОрг = ИдентификаторСсылки(Орг);
		Если Не ПустаяСтрока(ИдОрг) И КэшОрг[ИдОрг] = Неопределено Тогда
			Стр = Новый Структура("id,name,tax_id,kpp,address");
			Стр.id = ИдОрг;
			Стр.name = Строка(Орг);
			Стр.tax_id = "";
			Стр.kpp = "";
			Стр.address = "";
			Попытка
				Стр.tax_id = СокрЛП(Строка(Орг.ИНН));
			Исключение
			КонецПопытки;
			Попытка
				Стр.kpp = СокрЛП(Строка(Орг.КПП));
			Исключение
			КонецПопытки;
			Попытка
				Стр.address = СокрЛП(Строка(Орг.ЮридическийАдрес));
			Исключение
				Попытка
					Стр.address = СокрЛП(Строка(Орг.ФактическийАдрес));
				Исключение
				КонецПопытки;
			КонецПопытки;
			КэшОрг.Вставить(ИдОрг, Стр);
		КонецЕсли;
	КонецЕсли;

	ИмяСклад = ТекстРеквизитаШапки(ДокОб, ИменаРеквизитовСклад());
	Если Не ПустаяСтрока(ИмяСклад) Тогда
		Скл = ДокОб[ИмяСклад];
		ИдСкл = ИдентификаторСсылки(Скл);
		Если Не ПустаяСтрока(ИдСкл) И КэшСкладов[ИдСкл] = Неопределено Тогда
			СтрЛ = Новый Структура("id,name,type,legal_entity_id");
			СтрЛ.id = ИдСкл;
			СтрЛ.name = Строка(Скл);
			СтрЛ.type = "room";
			СтрЛ.legal_entity_id = "";
			Если Не ПустаяСтрока(ИмяОрг) Тогда
				СтрЛ.legal_entity_id = ИдентификаторСсылки(ДокОб[ИмяОрг]);
			КонецЕсли;
			КэшСкладов.Вставить(ИдСкл, СтрЛ);
		КонецЕсли;
	КонецЕсли;

	ТЧ = ПолучитьКоллекциюСтрокТоваров(ДокОб);
	Если ТЧ = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ИдОргДляАктива = "";
	Если Не ПустаяСтрока(ИмяОрг) Тогда
		ИдОргДляАктива = ИдентификаторСсылки(ДокОб[ИмяОрг]);
	КонецЕсли;

	Для Каждого СтрТЧ Из ТЧ Цикл
		Ном = Неопределено;
		Попытка
			Ном = СтрТЧ.Номенклатура;
		Исключение
		КонецПопытки;
		Если Ном = Неопределено Или Ном.Пустая() Тогда
			Продолжить;
		КонецЕсли;
		ИдНом = ИдентификаторСсылки(Ном);
		Если ПустаяСтрока(ИдНом) Тогда
			Продолжить;
		КонецЕсли;
		Если КэшНом[ИдНом] <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		СтрА = Новый Структура("id,name,inventory_number,serial_number,status,quantity,price,legal_entity_id,legal_entity_name,legal_entity_tax_id,employee_id,location_id");
		СтрА.id = ИдНом;
		СтрА.name = Строка(Ном);
		СтрА.inventory_number = "";
		Попытка
			СтрА.inventory_number = СокрЛП(Строка(Ном.Артикул));
		Исключение
		КонецПопытки;
		Если ПустаяСтрока(СтрА.inventory_number) Тогда
			СтрА.inventory_number = "INV-" + Лев(СтрЗаменить(ИдНом, "-", ""), 12);
		КонецЕсли;
		СтрА.serial_number = "";
		СтрА.status = "active";
		СтрА.quantity = "1";
		СтрА.price = "0";
		Попытка
			СтрА.quantity = Формат(СтрТЧ.Количество, "ЧРД=.; ЧГ=0");
		Исключение
		КонецПопытки;
		Попытка
			СтрА.price = Формат(СтрТЧ.Цена, "ЧРД=.; ЧГ=0");
		Исключение
		КонецПопытки;
		СтрА.legal_entity_id = ИдОргДляАктива;
		СтрА.legal_entity_name = "";
		СтрА.legal_entity_tax_id = "";
		Если Не ПустаяСтрока(ИдОргДляАктива) И КэшОрг[ИдОргДляАктива] <> Неопределено Тогда
			СтрА.legal_entity_name = КэшОрг[ИдОргДляАктива].name;
			СтрА.legal_entity_tax_id = КэшОрг[ИдОргДляАктива].tax_id;
		КонецЕсли;
		СтрА.employee_id = "";
		СтрА.location_id = "";
		Если Не ПустаяСтрока(ИмяСклад) Тогда
			СтрА.location_id = ИдентификаторСсылки(ДокОб[ИмяСклад]);
		КонецЕсли;

		КэшНом.Вставить(ИдНом, СтрА);
	КонецЦикла;

КонецПроцедуры

Процедура ЗаписатьЮрЛицо(Запись, Данные)

	Запись.ЗаписатьНачалоЭлемента("legal_entity");
	Запись.ЗаписатьАтрибут("id", Данные.id);
	Запись.ЗаписатьАтрибут("name", Данные.name);
	Запись.ЗаписатьАтрибут("tax_id", ?(ПустаяСтрока(Данные.tax_id), Данные.id, Данные.tax_id));
	Запись.ЗаписатьАтрибут("kpp", Данные.kpp);
	Запись.ЗаписатьАтрибут("address", Данные.address);
	Запись.ЗаписатьКонецЭлемента();

КонецПроцедуры

Процедура ЗаписатьЛокацию(Запись, Данные)

	Запись.ЗаписатьНачалоЭлемента("location");
	Запись.ЗаписатьАтрибут("id", Данные.id);
	Запись.ЗаписатьАтрибут("name", Данные.name);
	Запись.ЗаписатьАтрибут("type", Данные.type);
	Запись.ЗаписатьАтрибут("legal_entity_id", Данные.legal_entity_id);
	Запись.ЗаписатьКонецЭлемента();

КонецПроцедуры

Процедура ЗаписатьАктив(Запись, Данные)

	Запись.ЗаписатьНачалоЭлемента("asset");
	Запись.ЗаписатьАтрибут("id", Данные.id);
	Запись.ЗаписатьАтрибут("name", Данные.name);
	Запись.ЗаписатьАтрибут("inventory_number", Данные.inventory_number);
	Запись.ЗаписатьАтрибут("serial_number", Данные.serial_number);
	Запись.ЗаписатьАтрибут("status", Данные.status);
	Запись.ЗаписатьАтрибут("quantity", Данные.quantity);
	Запись.ЗаписатьАтрибут("price", Данные.price);
	Запись.ЗаписатьАтрибут("legal_entity_id", Данные.legal_entity_id);
	Запись.ЗаписатьАтрибут("legal_entity_name", Данные.legal_entity_name);
	Запись.ЗаписатьАтрибут("legal_entity_tax_id", Данные.legal_entity_tax_id);
	Запись.ЗаписатьАтрибут("employee_id", Данные.employee_id);
	Запись.ЗаписатьАтрибут("location_id", Данные.location_id);
	Запись.ЗаписатьКонецЭлемента();

КонецПроцедуры

Функция СтатусСессииПоДокументу(СсылкаДок)

	Попытка
		Если СсылкаДок.Проведен Тогда
			Возврат "completed";
		КонецЕсли;
	Исключение
	КонецПопытки;
	Возврат "in_progress";

КонецФункции

Процедура ЗаписатьСессиюИнвентаризации(Запись, СсылкаДок, КэшНом)

	ДокОб = СсылкаДок.ПолучитьОбъект();
	ИмяОрг = ТекстРеквизитаШапки(ДокОб, ИменаРеквизитовОрганизация());
	ИмяСклад = ТекстРеквизитаШапки(ДокОб, ИменаРеквизитовСклад());

	ИдСессии = ИдентификаторСсылки(СсылкаДок);
	ИдОрг = "";
	НаимОрг = "";
	ИннОрг = "";
	Если Не ПустаяСтрока(ИмяОрг) Тогда
		Орг = ДокОб[ИмяОрг];
		ИдОрг = ИдентификаторСсылки(Орг);
		НаимОрг = Строка(Орг);
		Попытка
			ИннОрг = СокрЛП(Строка(Орг.ИНН));
		Исключение
		КонецПопытки;
	КонецЕсли;

	ИдЛок = "";
	Если Не ПустаяСтрока(ИмяСклад) Тогда
		ИдЛок = ИдентификаторСсылки(ДокОб[ИмяСклад]);
	КонецЕсли;

	Запись.ЗаписатьНачалоЭлемента("inventory_session");
	Запись.ЗаписатьАтрибут("id", ИдСессии);
	Запись.ЗаписатьАтрибут("status", СтатусСессииПоДокументу(СсылкаДок));
	Запись.ЗаписатьАтрибут("legal_entity_id", ИдОрг);
	Запись.ЗаписатьАтрибут("legal_entity_name", НаимОрг);
	Запись.ЗаписатьАтрибут("legal_entity_tax_id", ИннОрг);
	Запись.ЗаписатьАтрибут("location_id", ИдЛок);
	Запись.ЗаписатьАтрибут("started_by_user_id", "");
	Запись.ЗаписатьАтрибут("conducted_by_employee_ids", "");
	Запись.ЗаписатьАтрибут("started_at", XMLСтрока(ДокОб.Дата));
	Запись.ЗаписатьАтрибут("finished_at", "");

	Запись.ЗаписатьНачалоЭлемента("items");

	ТЧ = ПолучитьКоллекциюСтрокТоваров(ДокОб);
	НПП = 0;
	Если ТЧ <> Неопределено Тогда
		Для Каждого СтрТЧ Из ТЧ Цикл
			Ном = Неопределено;
			Попытка
				Ном = СтрТЧ.Номенклатура;
			Исключение
			КонецПопытки;
			Если Ном = Неопределено Или Ном.Пустая() Тогда
				Продолжить;
			КонецЕсли;
			НПП = НПП + 1;
			ИдНом = ИдентификаторСсылки(Ном);
			ДанныеА = КэшНом[ИдНом];

			Запись.ЗаписатьНачалоЭлемента("item");
			Запись.ЗаписатьАтрибут("id", ИдСессии + "-" + Формат(НПП, "ЧГ=0"));
			Запись.ЗаписатьАтрибут("asset_id", ИдНом);
			Запись.ЗаписатьАтрибут("asset_name", Строка(Ном));
			Запись.ЗаписатьАтрибут("inventory_number", ?(ДанныеА = Неопределено, "", ДанныеА.inventory_number));
			Запись.ЗаписатьАтрибут("quantity", ?(ДанныеА = Неопределено, "1", ДанныеА.quantity));
			Запись.ЗаписатьАтрибут("price", ?(ДанныеА = Неопределено, "0", ДанныеА.price));
			Запись.ЗаписатьАтрибут("condition", "ok");
			Запись.ЗаписатьАтрибут("comment", "Выгрузка из 1С УНФ");
			Запись.ЗаписатьАтрибут("scanned_at", XMLСтрока(ДокОб.Дата));
			Запись.ЗаписатьАтрибут("detected", "true");
			Запись.ЗаписатьКонецЭлемента(); // item
		КонецЦикла;
	КонецЕсли;

	Запись.ЗаписатьКонецЭлемента(); // items
	Запись.ЗаписатьКонецЭлемента(); // inventory_session

КонецПроцедуры

#КонецОбласти
