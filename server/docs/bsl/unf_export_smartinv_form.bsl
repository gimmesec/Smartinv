// Модуль управляемой формы внешней обработки «Выгрузка инвентаризаций УНФ → XML SmartInv».
// В форме: стандартный реквизит «Объект», команда «ВыгрузитьВФайл» → эта процедура.

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыгрузитьВФайл(Команда)

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок = "Сохранить XML для SmartInv";
	Диалог.ПолноеИмяФайла = "smartinv_export_from_unf.xml";
	Диалог.Фильтр = "XML (*.xml)|*.xml";

	Если Не Диалог.Выбрать() Тогда
		Возврат;
	КонецЕсли;

	Путь = Диалог.ПолноеИмяФайла;
	ТекстОшибки = ВыполнитьВыгрузкуНаСервере(Путь);

	Если ПустаяСтрока(ТекстОшибки) Тогда
		ПоказатьПредупреждение(, "Файл сохранён:" + Символы.ПС + Путь);
	Иначе
		ПоказатьПредупреждение(, "Ошибка выгрузки:" + Символы.ПС + ТекстОшибки);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ВыполнитьВыгрузкуНаСервере(Знач ПолноеИмяФайла)

	Попытка
		Обработка = РеквизитФормыВЗначение("Объект");
		Обработка.ВыгрузитьИнвентаризацииВXML(ПолноеИмяФайла);
		Возврат "";
	Исключение
		Возврат ОписаниеОшибки();
	КонецПопытки;

КонецФункции

#КонецОбласти
